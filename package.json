{
  "name": "demex-sav-vercel",
  "version": "1.0.0",
  "description": "Application SAV Demex avec intégration Odoo - Déployée sur Vercel",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "node-fetch": "^2.6.7"
  },
"engines": {
  "node": "20.x"
}
}
{
  "version": 2,
  "builds": [
    {
      "src": "odoo.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "10mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/odoo",
      "dest": "/odoo.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
